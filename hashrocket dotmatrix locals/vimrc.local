set relativenumber
set number

" Turn off swap
set noswapfile
set nowb
set nobackup

" Indenting, no tab chars
set shiftwidth=2
set softtabstop=2
set expandtab

" Reload files that are changed outside of vim
set autoread

" Highlight search matches
set showmatch

" OSX C-c and C-x
vmap <C-x> :!reattach-to-user-namespace pbcopy<CR>
vmap <C-c> :w !reattach-to-user-namespace pbcopy<CR><CR>
